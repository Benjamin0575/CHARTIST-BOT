# ================================
# CHARTIST-BOT Configuration
# ================================

# IMPORTANT: Créer une copie nommée .env et remplir vos credentials

# ================================
# DERIV API CREDENTIALS
# ================================

# 1. Aller sur https://app.deriv.com/account/api-token
# 2. Créer une nouvelle application
# 3. Créer un API Token avec permissions "Trade" et "Admin"
# 4. Copier l'App ID et le Token ci-dessous

# Votre App ID Deriv
DERIV_APP_ID=your_deriv_app_id_here

# Votre API Token Deriv
DERIV_API_TOKEN=your_deriv_api_token_here


# ================================
# TELEGRAM ALERTS
# ================================

# 1. Chercher @BotFather sur Telegram
# 2. Envoyer /newbot pour créer un bot
# 3. Récupérer le token du bot
# 4. Envoyer un message à votre bot
# 5. Obtenir votre Chat ID via @userinfobot

# Token du bot Telegram (obtenu de BotFather)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Votre Chat ID Telegram (ID du channel ou direct)
TELEGRAM_CHAT_ID=your_telegram_chat_id_here


# ================================
# OPTIONNEL: Configuration Avancée
# ================================

# Account ID Deriv (si vous avez plusieurs comptes)
# DERIV_ACCOUNT_ID=

# Webhook URL pour intégrations custom
# WEBHOOK_URL=

# Mode de run
# RUN_MODE=production  # ou: development, backtest

# Niveau de log
# LOG_LEVEL=INFO  # DEBUG, INFO, WARNING, ERROR, CRITICAL
